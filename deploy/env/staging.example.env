# ChatCRM STAGING — copy to repo root as .env.staging (gitignored)
# Usage: DEPLOY_PROFILE=staging bun db:migrate
#        DEPLOY_PROFILE=staging bun run deploy:check

# ─── Supabase (project: chatcrm-staging) ───
VITE_SUPABASE_URL=https://YOUR_STAGING_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PROJECT_ID=your_staging_ref

# CLI migrations (optional — from Supabase Dashboard → Connect)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_STAGING_REF.supabase.co:5432/postgres
SUPABASE_POOLER_URL=postgresql://postgres.YOUR_STAGING_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres

# ─── App URL (Vercel staging) ───
VITE_APP_URL=https://chatcrm-staging.vercel.app
APP_ENV=production

# Optional hardening for /setup on shared staging
# SETUP_TOKEN=random-staging-secret

# ─── WhatsApp (optional — sandbox Meta + ngrok/Vercel URL) ───
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
