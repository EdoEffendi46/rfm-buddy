# ChatCRM CLIENT — copy to .env.client while onboarding one client (gitignored)
# Usage: DEPLOY_PROFILE=client bun db:migrate
#        DEPLOY_PROFILE=client bun run deploy:check
#
# After onboard: set the same keys in Vercel project env (client deploy).

# ─── Supabase (1 project = 1 client) ───
VITE_SUPABASE_URL=https://CLIENT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PROJECT_ID=client_ref

DATABASE_URL=postgresql://postgres:PASSWORD@db.CLIENT_REF.supabase.co:5432/postgres
SUPABASE_POOLER_URL=postgresql://postgres.CLIENT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres

# ─── App URL (client domain or Vercel) ───
VITE_APP_URL=https://crm.namabisnis.com
APP_ENV=production

# Recommended on production client deploy
SETUP_TOKEN=generate-long-random-string

# ─── WhatsApp Cloud API (optional — Standard package) ───
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
