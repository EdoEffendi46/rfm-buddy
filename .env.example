# Environment variables — dual backend (local pribadi + Lovable Cloud)
#
# LOCAL (Opsi B): copy block bawah ke .env.local — jangan commit.
# LOVABLE (Opsi A): Cloud → Secrets (auto dari connector), BUKAN file ini.
#
# Docs: .lovable/dual-backend-setup.md

# ─── LOCAL ONLY — paste ke .env.local ───

# VITE_SUPABASE_URL=https://YOUR_PRIVATE_PROJECT_REF.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# SUPABASE_SECRET_KEY=sb_secret_...
# VITE_APP_URL=http://localhost:8080
# SUPABASE_PROJECT_ID=your_private_ref
# SUPABASE_DATABASE_PASSWORD=...
# SUPABASE_POOLER_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres
# DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# Optional: require token on first /setup (production deploy hardening)
# SETUP_TOKEN=your-random-secret

# Local auth redirects (Supabase PRIBADI dashboard):
# http://localhost:8080/accept-invite
# http://localhost:8080/reset-password

# ─── LOVABLE CLOUD — set di Cloud → Secrets, not in repo ───
# VITE_SUPABASE_URL          → dari Lovable Cloud project
# VITE_SUPABASE_PUBLISHABLE_KEY
# SUPABASE_SECRET_KEY
# Redirect URLs → Lovable Cloud auth config (*.lovable.app)

# ─── GitHub Actions (optional, project pribadi) ───
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_ID=
# SUPABASE_DB_PASSWORD=
