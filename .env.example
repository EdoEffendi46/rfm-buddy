# Supabase (API Keys 2026 — publishable + secret only)
# Dashboard: Project → Settings → API Keys
# Docs: https://supabase.com/docs/guides/getting-started/api-keys

# Client-safe (Vite / browser)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server only — Secret keys tab (sb_secret_...). Never import in client code.
SUPABASE_SECRET_KEY=sb_secret_...

# Optional: direct Postgres (SQL Editor / CLI / migrations)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# GitHub Actions (Settings → Secrets → Actions) — auto migration on push to main
# SUPABASE_ACCESS_TOKEN=   # Dashboard → Account → Access Tokens
# SUPABASE_PROJECT_ID=     # Project ref, e.g. btdoqpowkfbssfdyygpm
# SUPABASE_DB_PASSWORD=    # Database password (Settings → Database)
